{
  "name": "@x-json/core",
  "version": "0.1.0",
  "description": "Parser and evaluator for XJSON, a superset of JSON5 with overrides and cross-file inheritance.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": ["xjson", "json5", "json", "config", "configuration", "override", "parser"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxaff/xJSON.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/xxaff/xJSON#readme",
  "bugs": "https://github.com/xxaff/xJSON/issues",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node-host.ts",
      "default": "./src/node-host.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
        "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
      },
      "./node": {
        "import": { "types": "./dist/node-host.d.ts", "default": "./dist/node-host.js" },
        "require": { "types": "./dist/node-host.d.cts", "default": "./dist/node-host.cjs" }
      }
    }
  }
}
