{
  "name": "@xjson/schema",
  "version": "0.1.0",
  "description": "JSON Schema written in XJSON, validated with AJV.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "keywords": ["xjson", "json-schema", "schema", "validation", "ajv"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxaff/xJSON.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/xxaff/xJSON#readme",
  "bugs": "https://github.com/xxaff/xJSON/issues",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xjson/core": "workspace:^",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
        "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
      }
    }
  }
}
